---
import '../styles/global.css';
import '../styles/components/layout.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Votre Prénom — Développeur Web Freelance',
  description = 'Sites et applications web pour TPE, artisans et indépendants. Livraison en 3 semaines, prix clairs, sans jargon.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <!-- <link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" /> -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <nav>
    <a href="/" class="nav-logo">Valentin Vinel ↗</a>
    <ul class="nav-links">
      <li><a href="#offres">Offres</a></li>
      <li><a href="#projets">Projets</a></li>
      <li><a href="#process">Process</a></li>
      <li><a href="#temoignages">Avis</a></li>
      <li><a href="#contact" class="nav-cta">Discutons →</a></li>
    </ul>
  </nav>

  <slot />

  <footer>
    <p>© 2026 Valentin Vinel · Développeur web freelance · Vaucluse · <a href="/mentions-legales" class="link-ml">Mentions légales</a></p>
  </footer>

  <button class="back-to-top" id="backToTop" aria-label="Retour en haut">↑</button>

</body>
</html>

<script>
  import { initReveal } from '../scripts/reveal.js';
  import { initBackToTop } from '../scripts/backToTop.js';
  import { initActiveNav } from '../scripts/activeNav.js';

  initReveal();
  initBackToTop();
  initActiveNav();
</script>
